#!/bin/sh
# NOTE: パスが通った場所にこのファイルのシンボリックリンクを置く
line="$1"
pdf="$2"
tex="$3"

if [ "$(uname)" = "Darwin" ]; then
  /Applications/Skim.app/Contents/SharedSupport/displayline -g "$line" "$tex" "$pdf"
elif [ -n "$WSLENV" ]; then
  "/mnt/c/Program Files/SumatraPDF/SumatraPDF.exe" "$pdf" -forward-search "$tex" "$line"
fi
